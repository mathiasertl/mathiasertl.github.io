{% extends "_base.jinja" %}
{% set current_page = "about" %}

{% block title %}About — {{ site.name }}{% endblock %}

{% block main %}
<main class="max-w-2xl mx-auto px-6 pt-36 pb-24">

  <h1 class="text-2xl font-light text-stone-900 mb-2 tracking-tight">About</h1>
  <p class="text-stone-400 text-sm mb-14 font-light">A little more about me.</p>

  <!-- Who I am -->
  <section class="mb-14">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Who I am</h2>
    <div class="space-y-4 text-stone-600 leading-relaxed font-light">
      <p>
        I grew up in [City / Country] and have been working in [field] for [X] years.
        My path started with [early interest or study] and led me toward [current focus].
      </p>
      <p>
        I believe in [value — e.g. building things that last / open knowledge / simplicity].
        Most of my work lives at the intersection of [domain A] and [domain B].
      </p>
    </div>
  </section>

  <!-- Outside work -->
  <section class="mb-14">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Outside work</h2>
    <div class="space-y-4 text-stone-600 leading-relaxed font-light">
      <p>
        Outside of a screen you'll find me [hobby — e.g. road cycling, hiking, cooking, reading].
        I'm particularly obsessed with [specific interest] right now.
      </p>
      <p>
        I also enjoy [another hobby or interest].
        If you share any of these interests, feel free to reach out.
      </p>
    </div>
  </section>

  <!-- Currently -->
  <section class="mb-14">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Currently</h2>
    <ul class="space-y-3">
      <li class="flex gap-4">
        <span class="text-stone-300 select-none pt-0.5">—</span>
        <div>
          <span class="text-stone-500 text-xs uppercase tracking-wide font-medium">Working on</span>
          <p class="text-stone-600 font-light mt-0.5">[What you're currently building or doing at work]</p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="text-stone-300 select-none pt-0.5">—</span>
        <div>
          <span class="text-stone-500 text-xs uppercase tracking-wide font-medium">Reading</span>
          <p class="text-stone-600 font-light mt-0.5">[Book / article / newsletter you're into]</p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="text-stone-300 select-none pt-0.5">—</span>
        <div>
          <span class="text-stone-500 text-xs uppercase tracking-wide font-medium">Thinking about</span>
          <p class="text-stone-600 font-light mt-0.5">[Something on your mind lately]</p>
        </div>
      </li>
    </ul>
  </section>

  <!-- Things I believe -->
  <section class="mb-14">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Things I believe</h2>
    <ul class="space-y-2 text-stone-600 font-light">
      <li class="flex gap-3"><span class="text-stone-300 select-none">·</span> [Belief or principle #1]</li>
      <li class="flex gap-3"><span class="text-stone-300 select-none">·</span> [Belief or principle #2]</li>
      <li class="flex gap-3"><span class="text-stone-300 select-none">·</span> [Belief or principle #3]</li>
      <li class="flex gap-3"><span class="text-stone-300 select-none">·</span> [Belief or principle #4]</li>
    </ul>
  </section>

  <!-- Contact CTA -->
  <section class="pt-6 border-t border-stone-200">
    <p class="text-stone-500 font-light mb-5">
      Want to talk? I'm always happy to chat about [topic], [topic], or just say hi.
    </p>
    <a href="mailto:{{ site.email }}"
       class="inline-flex items-center gap-2 px-5 py-2.5 bg-stone-900 text-stone-100 text-sm rounded-full hover:bg-stone-700 transition-colors font-light">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
      </svg>
      Send me an email
    </a>
  </section>

</main>
{% endblock %}

{% block footer_right %}
  <a href="index.html" class="hover:text-stone-600 transition-colors">Back to home</a>
{% endblock %}
