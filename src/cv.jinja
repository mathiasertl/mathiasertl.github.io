{% extends "_base.jinja" %}
{% set current_page = "cv" %}

{% block title %}Curriculum vitae — {{ site.name }}{% endblock %}

{% block main %}
<main class="max-w-2xl mx-auto px-6 pt-36 pb-24">

  <h1 class="text-2xl font-light text-stone-900 mb-2 tracking-tight">Curriculum Vitae (CV)</h1>
  <p class="text-stone-400 text-sm mb-14 font-light">Download my current CV.</p>

  <!-- PDF download -->
  <section class="mb-14">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Download as PDF</h2>
    <ul class="space-y-3">
      {% for pdf in pdfs %}
      <li>
        <a href="/static/{{ pdf.path }}" target="_blank" rel="noopener"
           class="flex items-center justify-between px-5 py-4 bg-white border border-stone-200 rounded-xl hover:border-stone-400 hover:shadow-sm transition-all group">
          <div class="flex items-center gap-4">
            {{ icon(pdf.icon|default("pdf")) }}
            <span class="text-stone-700 font-light group-hover:text-stone-900 transition-colors">{{ pdf.label }}</span>
          </div>
          <span class="text-xs text-stone-400 group-hover:text-stone-600 transition-colors">{{ pdf.path }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>

  <!-- source -->
  <section class="mb-14">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">LaTeX source</h2>
    <div class="space-y-4 text-stone-600 leading-relaxed font-light">
      <p>
         Find the LaTeX source at
         <a href="https://github.com/mathiasertl/cv/">https://github.com/mathiasertl/cv/</a>.
      </p>
    </div>
  </section>

</main>
{% endblock %}

{% block footer_right %}
  <a href="index.html" class="hover:text-stone-600 transition-colors">Back to home</a>
{% endblock %}
