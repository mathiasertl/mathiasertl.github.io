{% extends "_base.jinja" %}
{% set current_page = "links" %}

{# ── Page content — edit these lists to add/remove/reorder entries ── #}

{% block title %}Links — {{ site.name }}{% endblock %}


{% block main %}
<main class="max-w-2xl mx-auto px-6 pt-36 pb-24">

  <h1 class="text-2xl font-light text-stone-900 mb-2 tracking-tight">Links</h1>
  <p class="text-stone-400 text-sm mb-14 font-light">Where to find me on the internet.</p>

  <!-- Social / Professional -->
  <section class="mb-12">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Social &amp; Professional</h2>
    <ul class="space-y-3">
      {% for s in socials %}
      <li>
        <a href="{{ s.url }}" target="_blank" rel="noopener"
           class="flex items-center justify-between px-5 py-4 bg-white border border-stone-200 rounded-xl hover:border-stone-400 hover:shadow-sm transition-all group">
          <div class="flex items-center gap-4">
            {{ icon(s.icon) }}
            <span class="text-stone-700 font-light group-hover:text-stone-900 transition-colors">{{ s.label }}</span>
          </div>
          <span class="text-xs text-stone-400 group-hover:text-stone-600 transition-colors">{{ s.handle }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>

  <!-- Projects -->
  {% if projects %}
  <section class="mb-12">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Projects &amp; Work</h2>
    <ul class="space-y-3">
      {% for p in projects %}
      <li>
        <a href="{{ p.url }}" target="_blank" rel="noopener"
           class="flex items-center justify-between px-5 py-4 bg-white border border-stone-200 rounded-xl hover:border-stone-400 hover:shadow-sm transition-all group">
          <div class="flex items-center gap-4">
            <div class="w-5 h-5 flex items-center justify-center">
              <span class="block w-2 h-2 rounded-full bg-stone-300 group-hover:bg-stone-600 transition-colors"></span>
            </div>
            <div>
              <span class="text-stone-700 font-light group-hover:text-stone-900 transition-colors block">{{ p.name }}</span>
              <span class="text-xs text-stone-400">{{ p.description }}</span>
            </div>
          </div>
          <svg class="w-4 h-4 text-stone-300 group-hover:text-stone-500 transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
          </svg>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <!-- Contact -->
  <section>
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Contact</h2>
    <ul class="space-y-3">
      <li>
        <a href="mailto:{{ site.email }}"
           class="flex items-center justify-between px-5 py-4 bg-white border border-stone-200 rounded-xl hover:border-stone-400 hover:shadow-sm transition-all group">
          <div class="flex items-center gap-4">
            <svg class="w-5 h-5 text-stone-400 group-hover:text-stone-700 transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            <span class="text-stone-700 font-light group-hover:text-stone-900 transition-colors">Email</span>
          </div>
          <span class="text-xs text-stone-400 group-hover:text-stone-600 transition-colors">{{ site.email }}</span>
        </a>
      </li>
    </ul>
  </section>

</main>
{% endblock %}

{% block footer_right %}
  <a href="index.html" class="hover:text-stone-600 transition-colors">Back to home</a>
{% endblock %}
