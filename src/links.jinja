{% extends "_base.jinja" %}
{% set current_page = "links" %}

{# ── Page content — edit these lists to add/remove/reorder entries ── #}

{% set _socials = [
  {"label": "GitHub",    "handle": "@username",        "url": "https://github.com/username",         "icon": "github"},
  {"label": "LinkedIn",  "handle": "Your Name",         "url": "https://linkedin.com/in/username",    "icon": "linkedin"},
  {"label": "X / Twitter","handle": "@username",        "url": "https://twitter.com/username",        "icon": "twitter"},
  {"label": "Mastodon",  "handle": "@username@instance","url": "https://mastodon.social/@username",   "icon": "mastodon"},
] %}

{% set _projects = [
  {"name": "Project Name",    "url": "https://your-project.example.com",    "description": "Short description of the project."},
  {"name": "Another Project", "url": "https://another-project.example.com", "description": "Short description of the project."},
] %}

{% block title %}Links — {{ site.name }}{% endblock %}

{# ── SVG icon snippets, keyed by name ── #}
{% macro icon(name) %}
  {% if name == "github" %}
    <svg class="w-5 h-5 text-stone-400 group-hover:text-stone-700 transition-colors" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
    </svg>
  {% elif name == "linkedin" %}
    <svg class="w-5 h-5 text-stone-400 group-hover:text-stone-700 transition-colors" fill="currentColor" viewBox="0 0 24 24">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  {% elif name == "twitter" %}
    <svg class="w-5 h-5 text-stone-400 group-hover:text-stone-700 transition-colors" fill="currentColor" viewBox="0 0 24 24">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  {% elif name == "mastodon" %}
    <svg class="w-5 h-5 text-stone-400 group-hover:text-stone-700 transition-colors" fill="currentColor" viewBox="0 0 24 24">
      <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.664c0-1.56-.616-2.35-1.847-2.35-1.12 0-1.669.667-1.67 1.976v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"/>
    </svg>
  {% else %}
    <span class="block w-2 h-2 rounded-full bg-stone-300 group-hover:bg-stone-600 transition-colors"></span>
  {% endif %}
{% endmacro %}

{% block main %}
<main class="max-w-2xl mx-auto px-6 pt-36 pb-24">

  <h1 class="text-2xl font-light text-stone-900 mb-2 tracking-tight">Links</h1>
  <p class="text-stone-400 text-sm mb-14 font-light">Where to find me on the internet.</p>

  <!-- Social / Professional -->
  <section class="mb-12">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Social &amp; Professional</h2>
    <ul class="space-y-3">
      {% for s in socials %}
      <li>
        <a href="{{ s.url }}" target="_blank" rel="noopener"
           class="flex items-center justify-between px-5 py-4 bg-white border border-stone-200 rounded-xl hover:border-stone-400 hover:shadow-sm transition-all group">
          <div class="flex items-center gap-4">
            {{ icon(s.icon) }}
            <span class="text-stone-700 font-light group-hover:text-stone-900 transition-colors">{{ s.label }}</span>
          </div>
          <span class="text-xs text-stone-400 group-hover:text-stone-600 transition-colors">{{ s.handle }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>

  <!-- Projects -->
  {% if projects %}
  <section class="mb-12">
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Projects &amp; Work</h2>
    <ul class="space-y-3">
      {% for p in projects %}
      <li>
        <a href="{{ p.url }}" target="_blank" rel="noopener"
           class="flex items-center justify-between px-5 py-4 bg-white border border-stone-200 rounded-xl hover:border-stone-400 hover:shadow-sm transition-all group">
          <div class="flex items-center gap-4">
            <div class="w-5 h-5 flex items-center justify-center">
              <span class="block w-2 h-2 rounded-full bg-stone-300 group-hover:bg-stone-600 transition-colors"></span>
            </div>
            <div>
              <span class="text-stone-700 font-light group-hover:text-stone-900 transition-colors block">{{ p.name }}</span>
              <span class="text-xs text-stone-400">{{ p.description }}</span>
            </div>
          </div>
          <svg class="w-4 h-4 text-stone-300 group-hover:text-stone-500 transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
          </svg>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <!-- Contact -->
  <section>
    <h2 class="text-xs font-medium uppercase tracking-widest text-stone-400 mb-5">Contact</h2>
    <ul class="space-y-3">
      <li>
        <a href="mailto:{{ site.email }}"
           class="flex items-center justify-between px-5 py-4 bg-white border border-stone-200 rounded-xl hover:border-stone-400 hover:shadow-sm transition-all group">
          <div class="flex items-center gap-4">
            <svg class="w-5 h-5 text-stone-400 group-hover:text-stone-700 transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            <span class="text-stone-700 font-light group-hover:text-stone-900 transition-colors">Email</span>
          </div>
          <span class="text-xs text-stone-400 group-hover:text-stone-600 transition-colors">{{ site.email }}</span>
        </a>
      </li>
    </ul>
  </section>

</main>
{% endblock %}

{% block footer_right %}
  <a href="index.html" class="hover:text-stone-600 transition-colors">Back to home</a>
{% endblock %}
